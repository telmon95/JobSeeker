# MongoDB
MONGO_URI=mongodb://localhost:27017/jobseeker

# Data collections (see server/src/models/)
# users        — auth (email, password hash) + profile (parsedCV, fullName, preferences, cvMeta)
# jobs         — scraped listings with apply URLs and metadata
# applications — user job applications and cover letters
# jobmatches   — per-user CV match scores
# searchruns   — logged scrape/pipeline runs per user

# Auth
JWT_SECRET=your-jwt-secret

# OpenAI (cover letters + structured extraction)
OPENAI_API_KEY=sk-...

# LlamaParse (CV document parsing — PDF, Word, ODT, images)
LLAMA_CLOUD_API_KEY=llx-...
# Optional: fast | cost_effective | agentic (agentic for complex multi-column CVs)
CV_PARSE_TIER=cost_effective
# Optional: set true to use OpenAI for CV structuring (falls back to heuristic)
USE_OPENAI_CV_PARSING=false

# Google Jobs (SerpAPI — searches Google Jobs from the backend)
SERPAPI_API_KEY=your-serpapi-key
SCRAPE_MAX_PAGES=3

# Adzuna job API (optional fallback source)
ADZUNA_APP_ID=your-app-id
ADZUNA_APP_KEY=your-app-key
ADZUNA_COUNTRY=za

# Server
PORT=5001
